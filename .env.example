DATABASE_URL=postgresql://postgres:postgres@localhost:5432/substrata
API_URL=http://localhost:4000
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:3000
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./tmp/storage

# Google OAuth client credentials and API callback URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/v1/auth/google/callback

# Session secret used to hash opaque session and one-time auth tokens.
SESSION_SECRET=
SESSION_COOKIE_NAME=substrata_session
SESSION_COOKIE_DOMAIN=
PUBLIC_DEMO_ADMIN_EMAILS=

# Transactional email configuration.
EMAIL_PROVIDER=console
ZEPTOMAIL_SEND_MAIL_TOKEN=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Substrata
EMAIL_REPLY_TO=

# Execution backend worker settings.
# Use public datasheets only when sending documents to remote backends.
AI_MAX_INPUT_CHARS=120000
AI_DEMO_PUBLIC_DOCS_ONLY=true
AI_FALLBACK_TO_HEURISTIC=true

OLLAMA_HOST=http://localhost:11434
SUBSTRATA_EXECUTION_MODES=local,remote
LOCAL_LLM_PROVIDER=gemma
LOCAL_GEMMA_ENABLED=true
# AMD ROCm notebook default. Use LOCAL_GEMMA_RUNTIME=ollama to retain an Ollama deployment.
LOCAL_GEMMA_RUNTIME=transformers
LOCAL_GEMMA_MODEL=google/gemma-4-E4B-it
LOCAL_GEMMA_DEVICE=cuda
LOCAL_GEMMA_ATTENTION=eager
LOCAL_GEMMA_MAX_NEW_TOKENS=1024
LOCAL_GEMMA_TEMPERATURE=0
LOCAL_GEMMA_BASE_URL=http://localhost:11434
REMOTE_PROVIDER_STRATEGY=auto
REMOTE_PROVIDER_PRIORITY=junglegrid,fireworks,amd_notebook_manual
FIREWORKS_ENABLED=true
GEMMA_MODEL=google/gemma-4-E4B-it

FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_INPUT_TOKEN_USD=0.0000018
FIREWORKS_OUTPUT_TOKEN_USD=0.0000030

JUNGLE_GRID_API_URL=https://api.junglegrid.dev
JUNGLE_GRID_API_KEY=
JUNGLE_GRID_IMAGE=ghcr.io/jungle-grid/substrata-jungle-grid-inference:rocm
JUNGLE_GRID_MODEL=gemma4:12b
JUNGLE_GRID_RUNTIME_BACKEND=rocm
JUNGLE_GRID_GPU_VENDOR=AMD
JUNGLE_GRID_LIVE_TEST_ENABLED=false
JUNGLEGRID_ENABLED=false
AMD_NOTEBOOK_MANUAL_ENABLED=false


APP_URL=http://localhost:3001
WEB_APP_URL=http://localhost:3001
API_CORS_ORIGIN=http://localhost:3001
