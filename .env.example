# Substrata public Docker demo
# Copy this file to .env. Values below are local-only defaults or placeholders.

# PostgreSQL (required by Docker Compose)
POSTGRES_DB=substrata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/substrata?schema=public

# Web and API (required; safe local defaults)
APP_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:3000
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./tmp/storage
SESSION_SECRET=local-demo-only-replace-before-any-shared-deployment
SESSION_COOKIE_NAME=substrata_session
SESSION_COOKIE_DOMAIN=
PUBLIC_DEMO_ADMIN_EMAILS=

# Local email delivery (required setting; no external credentials)
EMAIL_PROVIDER=console
EMAIL_FROM_NAME=Substrata
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=

# Google OAuth (optional; password sign-in works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/v1/auth/google/callback

# Deterministic public-demo execution (no provider credential required)
AI_MAX_INPUT_CHARS=120000
AI_DEMO_PUBLIC_DOCS_ONLY=true
AI_FALLBACK_TO_HEURISTIC=true
SUBSTRATA_MIN_OWNED_PRODUCT_EVIDENCE=1
SUBSTRATA_EXECUTION_MODES=local,remote
LOCAL_GEMMA_ENABLED=false
FIREWORKS_ENABLED=false
JUNGLEGRID_ENABLED=false
AMD_NOTEBOOK_MANUAL_ENABLED=false

# Local Gemma assistance (optional; requires a separately managed runtime)
OLLAMA_HOST=http://host.docker.internal:11434
LOCAL_GEMMA_RUNTIME=ollama
LOCAL_GEMMA_MODEL=gemma4:e2b
LOCAL_GEMMA_BASE_URL=http://host.docker.internal:11434
LOCAL_GEMMA_DEVICE=cuda
LOCAL_GEMMA_ATTENTION=eager
LOCAL_GEMMA_MAX_NEW_TOKENS=1024
LOCAL_GEMMA_TEMPERATURE=0
GEMMA_MODEL=gemma4:e2b

# Fireworks remote assistance (optional)
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=90
FIREWORKS_MAX_RETRIES=2
FIREWORKS_INPUT_TOKEN_USD=0.0000018
FIREWORKS_OUTPUT_TOKEN_USD=0.0000030

# Jungle Grid / AMD ROCm prototype path (optional)
JUNGLE_GRID_API_URL=https://api.junglegrid.dev
JUNGLE_GRID_API_KEY=
JUNGLE_GRID_IMAGE=ghcr.io/jungle-grid/substrata-jungle-grid-inference:rocm
JUNGLE_GRID_MODEL=gemma4:12b
JUNGLE_GRID_RUNTIME_BACKEND=rocm
JUNGLE_GRID_GPU_VENDOR=AMD
JUNGLE_GRID_LIVE_TEST_ENABLED=false
REMOTE_PROVIDER_PRIORITY=junglegrid,fireworks,amd_notebook_manual

# Transactional email (optional; set EMAIL_PROVIDER=zeptomail)
ZEPTOMAIL_SEND_MAIL_TOKEN=

# Production-only aliases/settings (not needed by the public Docker demo)
ZEPTO_MAIL_API_TOKEN=
NODE_ENV=development
