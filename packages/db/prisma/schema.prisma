generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentSourceType {
  upload
  seed
  manual
}

enum ClassificationRunStatus {
  pending
  queued
  running
  completed
  failed
}

enum HumanReviewStatus {
  pending_review
  reviewed
  needs_more_information
  in_review
  approved
  rejected
}

enum MembershipRole {
  OWNER
  ADMIN
  REVIEWER
  ANALYST
  VIEWER
}

enum OAuthProvider {
  GOOGLE
}

model Organization {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  industry           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        Membership[]
  documents          Document[]
  classificationRuns ClassificationRun[]
  extractedSpecs     ExtractedSpec[]
  eccnCandidates     ECCNCandidate[]
  citations          Citation[]
  reviewMemos        ReviewMemo[]
  humanReviews       HumanReview[]
  auditEvents        AuditEvent[]
  sessions           Session[]
  workspaceInvites   WorkspaceInvite[]
}

model User {
  id                    String                   @id @default(cuid())
  email                 String                   @unique
  name                  String
  emailVerifiedAt       DateTime?
  onboardingCompletedAt DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  passwordCredential    PasswordCredential?
  oauthIdentities       OAuthIdentity[]
  sessions              Session[]
  memberships           Membership[]
  reviews               HumanReview[]
  auditEvents           AuditEvent[]
  verificationTokens    EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  sentWorkspaceInvites  WorkspaceInvite[]        @relation("WorkspaceInviteInviter")
  acceptedInvites       WorkspaceInvite[]        @relation("WorkspaceInviteAccepter")
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthIdentity {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  email             String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id              String        @id @default(cuid())
  userId          String
  organizationId  String
  tokenHash       String        @unique
  csrfTokenHash   String
  expiresAt       DateTime
  lastAccessedAt  DateTime      @default(now())
  revokedAt       DateTime?
  userAgent       String?
  ipAddress       String?
  rotatedFromId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([organizationId, expiresAt])
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Membership {
  id               String          @id @default(cuid())
  organizationId   String
  userId           String
  role             MembershipRole  @default(REVIEWER)
  invitedByUserId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, role])
}

model WorkspaceInvite {
  id               String          @id @default(cuid())
  organizationId   String
  email            String
  role             MembershipRole  @default(REVIEWER)
  tokenHash        String          @unique
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser    User            @relation("WorkspaceInviteInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedByUser   User?           @relation("WorkspaceInviteAccepter", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
  @@index([organizationId, expiresAt])
}

model Document {
  id                 String              @id @default(cuid())
  organizationId     String
  title              String
  fileName           String
  mimeType           String
  sizeBytes          Int?
  storagePath        String
  sourceType         DocumentSourceType  @default(upload)
  rawText            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRuns ClassificationRun[]

  @@index([organizationId, createdAt])
}

model ClassificationRun {
  id                    String                   @id @default(cuid())
  organizationId        String
  documentId            String
  status                ClassificationRunStatus  @default(pending)
  trigger               String                   @default("manual")
  confidence            Float?
  uncertaintyFlags      String[]
  requiresHumanReview   Boolean                  @default(true)
  workerJobId           String?
  workerVersion         String?
  rulesVersion          String?
  extractedTextPath     String?
  structuredOutputPath  String?
  memoArtifactPath      String?
  errorMessage          String?
  completedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document              Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedSpecs        ExtractedSpec[]
  eccnCandidates        ECCNCandidate[]
  reviewMemo            ReviewMemo?
  humanReviews          HumanReview[]
  citations             Citation[]

  @@index([organizationId, createdAt])
  @@index([documentId, createdAt])
}

model ExtractedSpec {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  name                String
  value               String
  unit                String?
  sourceSnippet       String
  importance          String
  confidence          Float
  confidenceLevel     String             @default("medium")
  category            String             @default("product_identity")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([classificationRunId])
}

model ECCNCandidate {
  id                    String             @id @default(cuid())
  organizationId        String
  classificationRunId   String
  eccn                  String
  title                 String
  rationale             String
  confidence            Float
  confidenceLevel       String             @default("medium")
  matchedTechnicalFacts String[]
  whyItMayApply         String
  whyItMayNotApply      String
  missingInformation    String[]
  reviewerQuestions     String[]
  uncertaintyFlags      String[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun     ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  citations             Citation[]

  @@index([organizationId, createdAt])
  @@index([classificationRunId])
}

model Citation {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  eccnCandidateId     String?
  sourceTitle         String
  sourceUrl           String?
  sourceSection       String?
  quotedText          String
  relevanceNote       String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  eccnCandidate       ECCNCandidate?     @relation(fields: [eccnCandidateId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([classificationRunId])
}

model ReviewMemo {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String             @unique
  contentMarkdown     String
  generatedBy         String             @default("worker_stub")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model HumanReview {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  reviewerId          String
  status              HumanReviewStatus  @default(pending_review)
  notes               String?
  reviewedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  reviewer            User               @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([classificationRunId, createdAt])
}

model AuditEvent {
  id             String        @id @default(cuid())
  organizationId String
  actorUserId    String?
  actor          String
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}
