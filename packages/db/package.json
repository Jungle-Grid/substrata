{
  "name": "@substrata/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src prisma --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "/bin/bash -lc 'set -a && source ../../.env && set +a && prisma generate'",
    "prisma:migrate": "/bin/bash -lc 'set -a && source ../../.env && set +a && prisma migrate dev --name init'",
    "prisma:studio": "/bin/bash -lc 'set -a && source ../../.env && set +a && prisma studio'",
    "seed": "/bin/bash -lc 'set -a && source ../../.env && set +a && tsx prisma/seed.ts'"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "prisma": "^6.10.1",
    "tsx": "^4.20.1"
  }
}
