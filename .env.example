DATABASE_URL=postgresql://postgres:postgres@localhost:5432/substrata
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:3000
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./tmp/storage
MOCK_ORGANIZATION_ID=org_demo
MOCK_USER_ID=user_demo
MOCK_USER_EMAIL=reviewer@substrata.local

# AI-assisted local worker demo mode.
# Use public datasheets only; do not upload confidential or proprietary documents.
AI_ENABLED=true
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_MAX_INPUT_CHARS=120000
AI_DEMO_PUBLIC_DOCS_ONLY=true
