DATABASE_URL=postgresql://postgres:postgres@localhost:5432/substrata
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:3000
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./tmp/storage

# Google OAuth client credentials and API callback URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/v1/auth/google/callback

# Session secret used to hash opaque session and one-time auth tokens.
SESSION_SECRET=
SESSION_COOKIE_NAME=substrata_session

# ZeptoMail transactional email configuration.
ZEPTO_MAIL_API_TOKEN=
EMAIL_FROM=Substrata <no-reply@example.com>

# AI-assisted local worker demo mode.
# Use public datasheets only; do not upload confidential or proprietary documents.
AI_ENABLED=true
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_MAX_INPUT_CHARS=120000
AI_DEMO_PUBLIC_DOCS_ONLY=true
