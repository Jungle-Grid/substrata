# Substrata production environment
# Required values are marked REQUIRED. Secrets must remain empty in this example.
# Run every production Compose command with:
# docker compose --env-file infra/.env.production ...

# Application URLs and ports
NODE_ENV=production
# REQUIRED: Public web origin used in links and redirects.
APP_URL=https://substrata.example.com
# REQUIRED: Canonical public web origin; normally the same as APP_URL.
WEB_APP_URL=https://substrata.example.com
# REQUIRED: Public API origin used by the API itself.
API_URL=https://api.substrata.example.com
# REQUIRED: Browser-facing API origin embedded into the web build.
NEXT_PUBLIC_API_BASE_URL=https://api.substrata.example.com
# REQUIRED: Allowed browser origin for API CORS.
API_CORS_ORIGIN=https://substrata.example.com
# API container and loopback proxy port.
API_PORT=4100
# Web container and loopback proxy port.
WEB_PORT=3100
# Optional host port for local VPS database inspection.
POSTGRES_PORT=5433

# Database
# REQUIRED: PostgreSQL database and role names. Use URL-safe characters.
POSTGRES_DB=substrata
POSTGRES_USER=substrata
# REQUIRED SECRET: PostgreSQL password. Use URL-safe characters because Compose builds DATABASE_URL.
POSTGRES_PASSWORD=

# Sessions and cookies
# REQUIRED SECRET: Long, random session signing/hashing secret.
SESSION_SECRET=
# Cookie name shared by API middleware.
SESSION_COOKIE_NAME=substrata_session
# Optional parent domain when API and web use different subdomains, e.g. .example.com.
SESSION_COOKIE_DOMAIN=.example.com

# Google OAuth
# Enable only after all three Google values are configured.
GOOGLE_OAUTH_ENABLED=false
# Optional OAuth client identifier.
GOOGLE_CLIENT_ID=
# OPTIONAL SECRET: required when GOOGLE_OAUTH_ENABLED=true.
GOOGLE_CLIENT_SECRET=
# Required when Google OAuth is enabled; must match the provider console.
GOOGLE_OAUTH_REDIRECT_URI=https://api.substrata.example.com/v1/auth/google/callback

# Transactional email
# REQUIRED: console or zeptomail. Production application validation requires zeptomail.
EMAIL_PROVIDER=zeptomail
# REQUIRED SECRET when EMAIL_PROVIDER=zeptomail.
ZEPTOMAIL_SEND_MAIL_TOKEN=
# Deprecated temporary alias; leave empty when the canonical token above is set.
ZEPTO_MAIL_API_TOKEN=
# REQUIRED when EMAIL_PROVIDER=zeptomail.
EMAIL_FROM_ADDRESS=noreply@example.com
# Display name for transactional messages.
EMAIL_FROM_NAME=Substrata
# Optional reply-to address.
EMAIL_REPLY_TO=support@example.com

# Execution and deterministic fallback
# Maximum document characters sent to an assisted backend.
AI_MAX_INPUT_CHARS=120000
# Permit deterministic fallback if a remote provider fails.
AI_FALLBACK_TO_HEURISTIC=false
# Minimum evidence items required to own a product identity.
SUBSTRATA_MIN_OWNED_PRODUCT_EVIDENCE=1
# Ordered remote-provider selection.
REMOTE_PROVIDER_PRIORITY=junglegrid,fireworks,amd_notebook_manual
# Manual notebook mode is disabled unless explicitly operated.
AMD_NOTEBOOK_MANUAL_ENABLED=false

# Gemini
# Reserved configuration only: Gemini is not wired into the current execution router.
GEMINI_ENABLED=false
# OPTIONAL SECRET: required by validation only if GEMINI_ENABLED=true.
GEMINI_API_KEY=

# Local Gemma / Ollama
LOCAL_GEMMA_ENABLED=false
LOCAL_GEMMA_RUNTIME=ollama
LOCAL_GEMMA_MODEL=gemma4:e2b
GEMMA_MODEL=gemma4:e2b
# Optional local runtime URL reachable from the API container.
LOCAL_GEMMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434
LOCAL_GEMMA_DEVICE=cuda
LOCAL_GEMMA_ATTENTION=eager
LOCAL_GEMMA_MAX_NEW_TOKENS=1024
LOCAL_GEMMA_TEMPERATURE=0

# Fireworks
FIREWORKS_ENABLED=false
# OPTIONAL SECRET: required when FIREWORKS_ENABLED=true.
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=90
FIREWORKS_MAX_RETRIES=3
FIREWORKS_INPUT_TOKEN_USD=0.0000018
FIREWORKS_OUTPUT_TOKEN_USD=0.0000030

# Jungle Grid / AMD ROCm prototype
JUNGLE_GRID_ENABLED=false
# Deprecated temporary alias for JUNGLE_GRID_ENABLED.
JUNGLEGRID_ENABLED=
JUNGLE_GRID_API_URL=https://api.junglegrid.dev
# OPTIONAL SECRET: required when JUNGLE_GRID_ENABLED=true.
JUNGLE_GRID_API_KEY=
JUNGLE_GRID_IMAGE=ghcr.io/jungle-grid/substrata-jungle-grid-inference:rocm
JUNGLE_GRID_MODEL=gemma4:12b
JUNGLE_GRID_RUNTIME_BACKEND=rocm
JUNGLE_GRID_GPU_VENDOR=AMD
# Disabled safety gate for the separate billable live-smoke script.
JUNGLE_GRID_LIVE_TEST_ENABLED=false

# Storage
# The current production Compose path supports local volume-backed storage.
STORAGE_DRIVER=local
# Container path is fixed by Compose to the named storage volume.
LOCAL_STORAGE_ROOT=/app/tmp/storage

# Public demo and diagnostics
# Optional comma-separated accounts allowed to publish demo runs.
PUBLIC_DEMO_ADMIN_EMAILS=
# Keep disabled unless temporary sanitized history diagnostics are required.
CLASSIFICATION_HISTORY_DIAGNOSTICS=0
